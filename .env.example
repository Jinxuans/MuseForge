# Server
ADDR=:5000
APP_URL=http://127.0.0.1:5000
LOG_LEVEL=info
LOG_FORMAT=text

# Optional database and storage. Leave DATABASE_URL empty for the lightweight sync proxy mode.
DATABASE_URL=
# DATABASE_URL=postgres://user:password@127.0.0.1:5432/museforge?sslmode=disable
DATA_DIR=./data
WORKER_CONCURRENCY=2
TASK_MAX_ATTEMPTS=3
RESULT_RETENTION_HOURS=168
CLEANUP_INTERVAL_MINUTES=30
CLEANUP_BATCH_SIZE=200
MAX_UPLOAD_MB=64

# Default upstream provider (TokFlux-first; OpenAI-compatible)
OPENAI_BASE_URL=https://api.tokenflux.cloud/v1
OPENAI_API_KEY=

# Official channel placeholders
DEFAULT_PROVIDER_BASE_URL=https://api.tokenflux.cloud/v1
DEFAULT_PROVIDER_API_KEY=

# Optional strict SSRF protection. Useful for public deployments.
STRICT_UPSTREAM_SECURITY=0

# Only used when STRICT_UPSTREAM_SECURITY=1.
ALLOW_INSECURE_UPSTREAMS=0
